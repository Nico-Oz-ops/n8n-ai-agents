    {
      "parameters": {
        "jsCode": "// 1. Legge il testo estratto dal nodo \"Extract from File\"\nconst text = $input.first().json.data;\n// → il file è già una stringa leggibile, non serve conversione binaria\n\n// 2. Divide il testo in righe\nconst lines = text.trim().split('\\n');\n// → crea un array: lines[0], lines[1], lines[2]...\n\n// 3. Intestazioni (lines[0]) - non ci servono ma documentano la struttura\nconst headers = lines[0].split(',');\n// → [\"stop_id\", \"stop_code\", \"stop_name\", \"stop_desc\", \"stop_lat\", \"stop_lon\", ...]\n\n// 4. Parte da i=1 per leggere le fermate\nconst items = [];\nfor (let i = 1; i < lines.length; i++) {\n  const values = lines[i].split(',');\n  if (values.length < 5) continue;\n  // → salta righe malformate\n\n  // 5. Per ogni riga prende i 4 valori di interesse\n  items.push({\n    json: {\n      stop_id: values[0].trim(),\n      stop_name: values[2].trim().replace(/\"/g, '').replace(/\\\\/g, ''), // rimuove virgolette e backslash\n      stop_lat: parseFloat(values[4]), // values[3] è stop_desc, lo saltiamo\n      stop_lon: parseFloat(values[5]),\n    }\n  });\n}\n\nreturn items;"
      },
